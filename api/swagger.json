  },
  "info": {
    "title": "API Documentation",
    "description": "API documentation for the application",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "Auth",
      "description": "Authentication related endpoints"
    }
  ],
  "servers": [
    {
      "url": "http://localhost:3001",
      "description": "Development server"
    }
  ],
  "components": {
    "securitySchemes": {
      "JWT-auth": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "name": "JWT",
        "description": "Enter JWT token",
        "in": "header"
      },
      "JWT-refresh": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "name": "Refresh-JWT",
        "description": "Enter refresh JWT token",
        "in": "header"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "User email address",
            "example": "john.doe@example.com"
          },
          "password": {
            "type": "string",
            "description": "User password",
            "example": "StrongP@ssw0rd!"
          },
          "firstName": {
            "type": "string",
            "description": "User first name",
            "example": "John"
          },
          "lastName": {
            "type": "string",
            "description": "User last name",
            "example": "Doe"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "Access token for authentication",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoxNTE2MjM5MDIyfQ.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c"
          },
          "refreshToken": {
            "type": "string",
            "description": "Refresh token for obtaining new access tokens",
            "example": "dGhpcy1pcz1hLXJlZnJlc2gtdG9rZW4tZXhhbXBsZS13aXRoLXN1ZmZpY2lhbC1jaGFyYWN0ZXJzIQ=="
          },
          "user": {
            "type": "object",
            "description": "Authenticated user information",
            "example": {
              "id": "user-123",
              "email": "<EMAIL>",
              "firstName": "John",
              "lastName": "Doe",
              "role": "USER"
            }
          }
        },
        "required": [
          "accessToken",
          "refreshToken",
          "user"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "User email address",
            "example": "john.doe@example.com"
          },
          "password": {
            "type": "string",
            "description": "User password",
            "example": "StrongP@ssw0rd!"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "UserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "User ID",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "email": {
            "type": "string",
            "description": "User email address",
            "example": "user@example.com"
          },
          "firstName": {
            "type": "object",
            "description": "User first name",
            "example": "John",
            "nullable": true
          },
          "lastName": {
            "type": "object",
            "description": "User last name",
            "example": "Doe",
            "nullable": true
          },
          "role": {
            "type": "string",
            "description": "User role",
            "enum": [
              "USER",
              "ADMIN"
            ]
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "description": "Account creation date",
            "example": "2023-10-01T12:34:56.789Z"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "description": "Last account update date",
            "example": "2023-10-10T12:34:56.789Z"
          }
        },
        "required": [
          "id",
          "email",
          "firstName",
          "lastName",
          "role",
          "createdAt",
          "updatedAt"
        ]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "User eamil address",
            "example": "user@example.com"
          },
          "firstName": {
            "type": "string",
            "description": "User first name",
            "example": "John"
          },
          "lastName": {
            "type": "string",
            "description": "User last name",
            "example": "Doe"
          }
        }
      },
      "ChangePasswordDto": {
        "type": "object",
        "properties": {
          "currentPassword": {
            "type": "string",
            "description": "New password for the user",
            "example": "NewP@ssw0rd!"
          },
          "newPassword": {
            "type": "string",
            "description": "New password for the user",
            "example": "NewP@ssw0rd!",
            "minLength": 8
          }
        },
        "required": [
          "currentPassword",
          "newPassword"
        ]
      },
      "CreateCategoryDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Electronics",
            "description": "The name of the category",
            "maxLength": 100
          },
          "description": {
            "type": "string",
            "example": "Devices and gadgets including phones, laptops, and accessories",
            "description": "A brief description of the category",
            "maxLength": 255
          },
          "slug": {
            "type": "string",
            "example": "electronics",
            "description": "The URL-friendly slug for the category",
            "maxLength": 100
          },
          "imageUrl": {
            "type": "string",
            "example": "https://example.com/images/electronics.png",
            "description": "URL of the category image",
            "maxLength": 255
          },
          "isActive": {
            "type": "boolean",
            "example": true,
            "description": "Indicates if the category is active",
            "default": true
          }
        },
        "required": [
          "name"
        ]
      },
      "Object": {
        "type": "object",
        "properties": {}
      },
      "CategoryResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "550e484-ere8458454-45erer4844858",
            "description": "The unique identifier of the category"
          },
          "name": {
            "type": "string",
            "example": "Electronics",
            "description": "The name of the category"
          },
          "description": {
            "type": "object",
            "example": "Devices and gadgets including phones, laptops, and accessories",
            "description": "A brief description of the category",
            "nullable": true
          },
          "slug": {
            "type": "object",
            "example": "electronics",
            "description": "The URL-friendly slug for the category",
            "nullable": true
          },
          "imageUrl": {
            "type": "object",
            "example": "https://example.com/images/electronics.png",
            "description": "URL of the category image",
            "nullable": true
          },
          "isActive": {
            "type": "boolean",
            "example": true,
            "description": "Indicates if the category is active"
          },
          "productCount": {
            "type": "number",
            "example": 150,
            "description": "Number of products in this category"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "example": "2024-01-01T12:00:00Z",
            "description": "The date and time when the category was created"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "example": "2024-01-10T15:30:00Z",
            "description": "The date and time when the category was last updated"
          }
        },
        "required": [
          "id",
          "name",
          "description",
          "slug",
          "imageUrl",
          "isActive",
          "productCount",
          "createdAt",
          "updatedAt"
        ]
      }
    }
  }
}